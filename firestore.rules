rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read, update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /email_analyses/{analysisId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /url_analyses/{analysisId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /domain_blacklist/{domainId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /indicator_rules/{ruleId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /audit_log/{eventId} {
      allow read: if isAdmin();
      allow create: if signedIn();
      allow update, delete: if false;
    }
  }
}
